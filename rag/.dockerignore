# Git
.git
.gitignore

# Python caching and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# Virtual Environments (This is usually the main 3GB culprit!)
venv/
env/
.venv/
/install/
venv

# Environment Variables (Crucial for security, never commit these to Docker)
.env
.env.*

# IDEs and Editor settings
.vscode/
.idea/
*.swp

# Local Databases, Vector Stores, and Uploads 
# (If you are working with AI, document processing, or local databases, 
# these folders get massive and should not be in the image)
*.db
*.sqlite3
chroma/
chromadb/
faiss_index/
data/
uploads/
docs/